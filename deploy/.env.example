# Secrets
LANDOLFIO_SECRET_KEY=secret
POSTGRES_PASSWORD=landolfio
SENTRY_DSN=https://xxxxxxx.ingest.sentry.io/xxxxxxx

# Moneybird
MONEYBIRD_ADMINISTRATION_ID=0
MONEYBIRD_API_KEY=
MONEYBIRD_WEBHOOK_ID=
MONEYBIRD_WEBHOOK_TOKEN=
MONEYBIRD_MARGIN_ASSETS_LEDGER_ACCOUNT_ID=
MONEYBIRD_NOT_MARGIN_ASSETS_LEDGER_ACCOUNT_ID=

# Ninox
NINOX_API_TOKEN=
NINOX_TEAM_ID=
NINOX_DATABASE_ID=

# AWS / S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USE_SSL=False
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_EMAIL=

# Non-secret config (varies per deployment).
#
# DJANGO_HOSTNAME is the one hostname Caddy terminates TLS for and serves on
# this VM. The web healthcheck also uses it for its `Host:` header.
#
# DJANGO_ALLOWED_HOSTS is Django's allowlist — comma-separated. Include
# DJANGO_HOSTNAME plus any other hostname whose traffic reaches Django via an
# upstream reverse proxy (e.g. cdn / cloudflare / another nginx that fronts
# this stack on a different domain).
DJANGO_HOSTNAME=landolfio.vofdoesburg.nl
DJANGO_ALLOWED_HOSTS=landolfio.vofdoesburg.nl,landolfio.jobdoesburg.dev
DJANGO_LOG_LEVEL=INFO
NOTIFICATION_EMAIL=contact@vofdoesburg.nl
PUBLIC_CONTACT_EMAIL=contact@vofdoesburg.nl
